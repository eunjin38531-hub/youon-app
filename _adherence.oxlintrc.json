{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/core/**",
              "components/dating/**",
              "components/emoticons/**",
              "components/feedback/**",
              "components/navigation/**",
              "deck-stage.js",
              "ui_kits/yuon-app/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Pretendard))/i]",
        "message": "Font not provided by the design system. Available: Pretendard."
      },
      {
        "selector": "JSXOpeningElement[name.name='Avatar'] > JSXAttribute > JSXIdentifier[name!=/^(?:src|alt|name|size|verified|ring|key|ref|className|style|children)$/]",
        "message": "<Avatar> doesn't accept that prop. Declared props: src, alt, name, size, verified, ring."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:tone|icon|size|children|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: tone, icon, size, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:trust|primary|accent|neutral|solid)$/]",
        "message": "<Badge> tone must be one of 'trust' | 'primary' | 'accent' | 'neutral' | 'solid'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md)$/]",
        "message": "<Badge> size must be one of 'sm' | 'md'."
      },
      {
        "selector": "JSXOpeningElement[name.name='TabDef'] > JSXAttribute > JSXIdentifier[name!=/^(?:key|label|icon|key|ref|className|style|children)$/]",
        "message": "<TabDef> doesn't accept that prop. Declared props: key, label, icon."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|size|fullWidth|disabled|leadingIcon|trailingIcon|children|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: variant, size, fullWidth, disabled, leadingIcon, trailingIcon, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|accent|secondary|ghost)$/]",
        "message": "<Button> variant must be one of 'primary' | 'accent' | 'secondary' | 'ghost'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:lg|md|sm)$/]",
        "message": "<Button> size must be one of 'lg' | 'md' | 'sm'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute > JSXIdentifier[name!=/^(?:padding|radius|interactive|elevated|children|key|ref|className|style|children)$/]",
        "message": "<Card> doesn't accept that prop. Declared props: padding, radius, interactive, elevated, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='ChatBubble'] > JSXAttribute > JSXIdentifier[name!=/^(?:from|time|children|key|ref|className|style|children)$/]",
        "message": "<ChatBubble> doesn't accept that prop. Declared props: from, time, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='ChatBubble'] > JSXAttribute[name.name='from'] > Literal[value!=/^(?:me|them)$/]",
        "message": "<ChatBubble> from must be one of 'me' | 'them'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Checkbox'] > JSXAttribute > JSXIdentifier[name!=/^(?:checked|onChange|label|round|disabled|style|key|ref|className|style|children)$/]",
        "message": "<Checkbox> doesn't accept that prop. Declared props: checked, onChange, label, round, disabled, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='FortuneBanner'] > JSXAttribute > JSXIdentifier[name!=/^(?:fortune|element|mascot|onMore|key|ref|className|style|children)$/]",
        "message": "<FortuneBanner> doesn't accept that prop. Declared props: fortune, element, mascot, onMore."
      },
      {
        "selector": "JSXOpeningElement[name.name='HeartButton'] > JSXAttribute > JSXIdentifier[name!=/^(?:kind|active|iconOnly|key|ref|className|style|children)$/]",
        "message": "<HeartButton> doesn't accept that prop. Declared props: kind, active, iconOnly."
      },
      {
        "selector": "JSXOpeningElement[name.name='HeartButton'] > JSXAttribute[name.name='kind'] > Literal[value!=/^(?:interest|quiet)$/]",
        "message": "<HeartButton> kind must be one of 'interest' | 'quiet'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Icon'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|size|color|strokeWidth|filled|key|ref|className|style|children)$/]",
        "message": "<Icon> doesn't accept that prop. Declared props: name, size, color, strokeWidth, filled."
      },
      {
        "selector": "JSXOpeningElement[name.name='IconButton'] > JSXAttribute > JSXIdentifier[name!=/^(?:icon|variant|size|ariaLabel|disabled|key|ref|className|style|children)$/]",
        "message": "<IconButton> doesn't accept that prop. Declared props: icon, variant, size, ariaLabel, disabled."
      },
      {
        "selector": "JSXOpeningElement[name.name='IconButton'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:plain|soft|primary|accent)$/]",
        "message": "<IconButton> variant must be one of 'plain' | 'soft' | 'primary' | 'accent'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Input'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|error|help|suffix|style|key|ref|className|style|children)$/]",
        "message": "<Input> doesn't accept that prop. Declared props: label, error, help, suffix, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='ListRow'] > JSXAttribute > JSXIdentifier[name!=/^(?:icon|label|value|right|chevron|danger|onClick|key|ref|className|style|children)$/]",
        "message": "<ListRow> doesn't accept that prop. Declared props: icon, label, value, right, chevron, danger, onClick."
      },
      {
        "selector": "JSXOpeningElement[name.name='MatchScore'] > JSXAttribute > JSXIdentifier[name!=/^(?:score|variant|size|label|key|ref|className|style|children)$/]",
        "message": "<MatchScore> doesn't accept that prop. Declared props: score, variant, size, label."
      },
      {
        "selector": "JSXOpeningElement[name.name='MatchScore'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:bar|ring|chip)$/]",
        "message": "<MatchScore> variant must be one of 'bar' | 'ring' | 'chip'."
      },
      {
        "selector": "JSXOpeningElement[name.name='MatchScore'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:md|lg)$/]",
        "message": "<MatchScore> size must be one of 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='ProfileFeedCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:photo|name|age|score|activity|sajuTag|intro|verified|key|ref|className|style|children)$/]",
        "message": "<ProfileFeedCard> doesn't accept that prop. Declared props: photo, name, age, score, activity, sajuTag, intro, verified."
      },
      {
        "selector": "JSXOpeningElement[name.name='ScoreBanner'] > JSXAttribute > JSXIdentifier[name!=/^(?:score|message|date|key|ref|className|style|children)$/]",
        "message": "<ScoreBanner> doesn't accept that prop. Declared props: score, message, date."
      },
      {
        "selector": "JSXOpeningElement[name.name='SegmentedTabs'] > JSXAttribute > JSXIdentifier[name!=/^(?:tabs|active|onChange|key|ref|className|style|children)$/]",
        "message": "<SegmentedTabs> doesn't accept that prop. Declared props: tabs, active, onChange."
      },
      {
        "selector": "JSXOpeningElement[name.name='Sticker'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|size|showLabel|spriteSrc|style|key|ref|className|style|children)$/]",
        "message": "<Sticker> doesn't accept that prop. Declared props: name, size, showLabel, spriteSrc, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Switch'] > JSXAttribute > JSXIdentifier[name!=/^(?:checked|onChange|disabled|style|key|ref|className|style|children)$/]",
        "message": "<Switch> doesn't accept that prop. Declared props: checked, onChange, disabled, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Tag'] > JSXAttribute > JSXIdentifier[name!=/^(?:tone|active|selectable|children|key|ref|className|style|children)$/]",
        "message": "<Tag> doesn't accept that prop. Declared props: tone, active, selectable, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Tag'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:neutral|primary|accent)$/]",
        "message": "<Tag> tone must be one of 'neutral' | 'primary' | 'accent'."
      },
      {
        "selector": "JSXOpeningElement[name.name='TopAppBar'] > JSXAttribute > JSXIdentifier[name!=/^(?:title|left|right|transparent|key|ref|className|style|children)$/]",
        "message": "<TopAppBar> doesn't accept that prop. Declared props: title, left, right, transparent."
      },
      {
        "selector": "JSXOpeningElement[name.name='TopicChip'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|key|ref|className|style|children)$/]",
        "message": "<TopicChip> doesn't accept that prop. Declared props: children."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
